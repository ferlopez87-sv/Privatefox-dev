{
  "name": "privatefox-extension",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "lint": "web-ext lint --source-dir dist",
    "start": "web-ext run --source-dir dist --target firefox-desktop",
    "package": "web-ext build --source-dir dist --overwrite-dest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.1",
    "@samrum/vite-plugin-web-extension": "^5.1.1",
    "@types/chrome": "^0.0.287",
    "@types/firefox-webext-browser": "^120.0.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.11",
    "vitest": "^2.1.9",
    "web-ext": "^8.3.0"
  }
}
